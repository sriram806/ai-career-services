# ============================================
# AI Career OS — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env files with real secrets.
# ============================================

# ---- Application ----
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000

# ---- PostgreSQL ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ai_career_os
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=ai_career_os

# ---- MongoDB ----
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=ai_career_os
MONGO_PASSWORD=changeme_mongo
MONGO_DB=ai_career_os
MONGO_URI=mongodb://ai_career_os:changeme_mongo@localhost:27017/ai_career_os?authSource=admin

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis

# ---- JWT (Placeholder) ----
JWT_SECRET=changeme_jwt_secret_minimum_32_chars_long
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ---- CORS ----
CORS_ORIGIN=http://localhost:3000

# ---- Rate Limiting (Placeholder) ----
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ---- S3 Compatible Storage (Placeholder) ----
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=changeme_s3_access
S3_SECRET_KEY=changeme_s3_secret
S3_BUCKET=ai-career-os
S3_REGION=us-east-1

# ---- AI Service ----
AI_SERVICE_URL=http://localhost:3005
OPENAI_API_KEY=changeme_openai_key

# ---- Kafka (Future) ----
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ai-career-os
KAFKA_GROUP_ID=ai-career-os-group

# ---- Service Ports ----
GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
CAREER_SERVICE_PORT=3003
EXAM_SERVICE_PORT=3004
AI_SERVICE_PORT=3005
ORG_SERVICE_PORT=3006
BILLING_SERVICE_PORT=3007
NOTIFICATION_SERVICE_PORT=3008
ADMIN_SERVICE_PORT=3009
ANALYTICS_SERVICE_PORT=3010

# ---- pgAdmin ----
PGADMIN_EMAIL=admin@aicareer.os
PGADMIN_PASSWORD=changeme_pgadmin

# ---- Mongo Express ----
MONGO_EXPRESS_PORT=8081

# ---- SMTP Mailer ----
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM="AI Career OS <noreply@aicareer.os>"

